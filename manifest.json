{
  "manifest_version": 3,
  "name": "Locked In",
  "version": "1.6.0",
  "description": "Blocks distracting sites on your schedule, and keeps Twitter, X, and TikTok videos blocked around the clock.",
  "permissions": [
    "declarativeNetRequest",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "*://*.twitter.com/*", "*://*.x.com/*", "*://*.tiktok.com/*", "*://*.instagram.com/*",
    "*://*.threads.net/*", "*://*.pinterest.com/*", "*://*.tumblr.com/*", "*://*.discord.com/*",
    "*://*.reddit.com/*", "*://*.9gag.com/*", "*://*.imgur.com/*", "*://*.twitch.tv/*",
    "*://*.netflix.com/*", "*://*.hulu.com/*", "*://*.disneyplus.com/*", "*://*.max.com/*",
    "*://*.primevideo.com/*", "*://*.peacocktv.com/*", "*://*.cnn.com/*", "*://*.foxnews.com/*",
    "*://*.bbc.com/*", "*://*.nytimes.com/*", "*://*.theguardian.com/*", "*://*.huffpost.com/*",
    "*://*.buzzfeed.com/*", "*://*.pornhub.com/*", "*://*.xvideos.com/*", "*://*.xnxx.com/*",
    "*://*.onlyfans.com/*", "*://*.xhamster.com/*", "*://*.youtube.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*", "*://youtube.com/*"],
      "js": ["content-scripts/youtube.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://www.linkedin.com/*", "*://linkedin.com/*"],
      "js": ["content-scripts/linkedin.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://www.facebook.com/*", "*://facebook.com/*"],
      "js": ["content-scripts/facebook.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://tiktok.com/*", "*://www.tiktok.com/*"],
      "js": ["content-scripts/tiktok.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["blocked/blocked.html"],
      "matches": [
        "*://*.twitter.com/*", "*://*.x.com/*", "*://*.tiktok.com/*", "*://*.instagram.com/*",
        "*://*.threads.net/*", "*://*.pinterest.com/*", "*://*.tumblr.com/*", "*://*.discord.com/*",
        "*://*.reddit.com/*", "*://*.9gag.com/*", "*://*.imgur.com/*", "*://*.twitch.tv/*",
        "*://*.netflix.com/*", "*://*.hulu.com/*", "*://*.disneyplus.com/*", "*://*.max.com/*",
        "*://*.primevideo.com/*", "*://*.peacocktv.com/*", "*://*.cnn.com/*", "*://*.foxnews.com/*",
        "*://*.bbc.com/*", "*://*.nytimes.com/*", "*://*.theguardian.com/*", "*://*.huffpost.com/*",
        "*://*.buzzfeed.com/*", "*://*.pornhub.com/*", "*://*.xvideos.com/*", "*://*.xnxx.com/*",
        "*://*.onlyfans.com/*", "*://*.xhamster.com/*", "*://*.youtube.com/*"
      ]
    }
  ]
}
